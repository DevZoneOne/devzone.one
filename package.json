{
  "name": "devzone.one",
  "version": "1.0.0",
  "description": "DevZone.one tech blog",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "watch:sass": "sass --no-source-map --pkg-importer=node --watch sass:assets/css",
    "watch:hugo": "hugo server -D",
    "build:sass": "sass --no-source-map --pkg-importer=node sass:assets/css",
    "build:hugo": "hugo --minify",
    "start": "npm-run-all build:sass --parallel watch:*",
    "build": "npm-run-all build:sass build:hugo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DevZoneOne/devzone.one.git"
  },
  "author": "DevZone.one",
  "bugs": {
    "url": "https://github.com/DevZoneOne/devzone.one/issues"
  },
  "homepage": "https://devzone.one",
  "devDependencies": {
    "@divezone/divezone-web-styles": "^1.3.5"
  }
}
